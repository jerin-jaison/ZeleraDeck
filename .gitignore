# ZeleraDeck — Root .gitignore

# ─── Python / Django ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Virtual environments
.venv/
venv/
env/
ENV/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# Environment files — NEVER commit secrets
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production

# ─── Node / React ────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/

# ─── IDE / OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ─── Files folder (project docs — skip if private) ───────────────
# Uncomment if you want to keep files/ private:
# files/
